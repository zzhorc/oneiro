{
  "name": "oneiro",
  "description": "Oneiro - A Chrome extension for new tab with Chinese poems and bookmarks",
  "version": "2.3.0",
  "scripts": {
    "pre": "wxt prepare",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:safari": "wxt build -b safari && xcrun /Applications/Xcode.app/Contents/Developer/usr/bin/safari-web-extension-converter --bundle-identifier com.github.xxnuo.jizhi-mod --project-location .output/safari-xcode .output/safari-mv2",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:all": "wxt zip && wxt zip -b firefox && wxt zip -b edge",
    "split": "cd ./assets/fonts && node ./split.mjs"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "animate.css": "^4.1.1",
    "cn-font-split": "^7.4.1",
    "daisyui": "^5.5.18",
    "driver.js": "^1.4.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0",
    "sentences-bundle": "^1.0.393",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "wxt": "^0.20.13"
  },
  "packageManager": "pnpm@9.12.2+sha512.22721b3a11f81661ae1ec68ce1a7b879425a1ca5b991c975b074ac220b187ce56c708fe5db69f4c962c989452eee76c82877f4ee80f474cebd61ee13461b6228"
}
